# ============================================================================
# SQL Agent Backend Configuration
# ============================================================================
# Copy this file to .env and fill in your values.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | azure_serverless | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1

# Azure AI Serverless (uncomment if using)
# LLM_PROVIDER=azure_serverless
# AZURE_AI_ENDPOINT=https://your-endpoint.eastus.inference.ml.azure.com
# AZURE_AI_API_KEY=your-azure-key
# AZURE_AI_MODEL=deepseek-v3

# Anthropic Claude (uncomment if using)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Performance / Scaling ────────────────────────────────────────────────────
# LLM response cache (reduces duplicate API calls)
LLM_CACHE_ENABLED=1
LLM_CACHE_MAX_SIZE=200

# Database connection pool size
DB_POOL_SIZE=20

# Max concurrent user sessions
MAX_CONNECTIONS=100

# CORS – comma-separated origins (use * for local dev)
ALLOWED_ORIGINS=*

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=8001
# SQLAGENT_RELOAD=1
# SQLAGENT_WORKERS=4

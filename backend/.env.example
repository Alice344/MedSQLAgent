# Copy this file to ".env" in the same folder (backend/) and fill in your key.
# The file ".env" is gitignored.

OPENAI_API_KEY=sk-your-key-here

# Optional — default is gpt-4o-mini (good for SQL generation)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EXPLAIN_MODEL=gpt-4o-mini

# Set to 0 so saving code does not reload the API (avoids losing DB sessions during dev)
# SQLAGENT_RELOAD=0
